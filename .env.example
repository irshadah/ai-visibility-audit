# Railway sets PORT and DATABASE_URL when you add the Postgres plugin.
PORT=5001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_audit

# Optional: for AI Visibility tab
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

AI_VIS_TIMEOUT_SEC=30
AI_VIS_MAX_PROMPTS=12
AI_VIS_OPENAI_MODEL=gpt-4o-mini
AI_VIS_GEMINI_MODEL=gemini-2.0-flash
AI_VIS_ANTHROPIC_MODEL=claude-3-5-haiku-latest
