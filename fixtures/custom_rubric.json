{
  "version": "2026.03-custom-demo",
  "category_weights": {
    "geo_structure": 0.35,
    "content_quality": 0.25,
    "semantic_quality": 0.20,
    "ux_signals": 0.10,
    "feed_quality": 0.10
  },
  "confidence_gate": 70,
  "rules": {
    "geo_structure": [
      {"id": "G1", "weight": 20, "type": "binary", "field": "schema.product_present", "impact": 5},
      {"id": "G2", "weight": 30, "type": "ratio", "field": "schema.required_field_coverage", "impact": 5},
      {"id": "G3", "weight": 10, "type": "binary", "field": "page.indexable", "impact": 4},
      {"id": "G4", "weight": 10, "type": "ratio", "field": "page.og_coverage", "impact": 3},
      {"id": "G5", "weight": 10, "type": "binary", "field": "page.url_hygiene", "impact": 2},
      {"id": "G6", "weight": 10, "type": "binary", "field": "page.price_availability_machine_readable", "impact": 4},
      {"id": "G7", "weight": 10, "type": "binary", "field": "page.variant_clarity", "impact": 3}
    ],
    "content_quality": [
      {"id": "C1", "weight": 15, "type": "range", "field": "content.title_length", "min": 40, "max": 140, "impact": 3},
      {"id": "C2", "weight": 20, "type": "threshold", "field": "content.description_length", "min": 300, "impact": 4},
      {"id": "C3", "weight": 25, "type": "ratio", "field": "content.attribute_completeness", "impact": 5},
      {"id": "C4", "weight": 10, "type": "binary", "field": "content.pricing_clarity", "impact": 4},
      {"id": "C5", "weight": 10, "type": "binary", "field": "content.policy_clarity", "impact": 3},
      {"id": "C6", "weight": 10, "type": "binary", "field": "content.review_presence", "impact": 2},
      {"id": "C7", "weight": 10, "type": "binary", "field": "content.support_trust_info", "impact": 2}
    ],
    "semantic_quality": [
      {"id": "L1", "weight": 25, "type": "inverse_threshold", "field": "semantic.ambiguity_count", "max": 3, "impact": 3},
      {"id": "L2", "weight": 25, "type": "ratio", "field": "semantic.entity_consistency", "impact": 4},
      {"id": "L3", "weight": 25, "type": "ratio", "field": "semantic.query_answerability", "impact": 4},
      {"id": "L4", "weight": 25, "type": "ratio", "field": "semantic.factual_grounding", "impact": 4}
    ],
    "ux_signals": [
      {"id": "U1", "weight": 30, "type": "binary", "field": "ux.render_accessibility", "impact": 3},
      {"id": "U2", "weight": 30, "type": "binary", "field": "ux.core_discoverability", "impact": 3},
      {"id": "U3", "weight": 20, "type": "ratio", "field": "ux.media_quality", "impact": 2},
      {"id": "U4", "weight": 20, "type": "binary", "field": "ux.mobile_readability", "impact": 2}
    ],
    "feed_quality": [
      {"id": "F1", "weight": 30, "type": "ratio", "field": "feed.required_coverage", "impact": 5},
      {"id": "F2", "weight": 20, "type": "ratio", "field": "feed.attribute_completeness", "impact": 4},
      {"id": "F3", "weight": 20, "type": "ratio", "field": "feed.validity", "impact": 4},
      {"id": "F4", "weight": 20, "type": "ratio", "field": "feed.page_consistency", "impact": 4},
      {"id": "F5", "weight": 10, "type": "ratio", "field": "feed.freshness", "impact": 3}
    ]
  },
  "recommendation_map": {
    "G2": "Add missing required Product/Offer schema fields.",
    "C2": "Expand description with concrete specs and use-cases.",
    "C3": "Complete required and recommended product attributes.",
    "L2": "Align brand/model/price entities between schema and visible content.",
    "F1": "Populate all required Merchant feed fields."
  }
}
